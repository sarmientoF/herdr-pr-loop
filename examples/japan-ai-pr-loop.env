# Example only. Copy to .herdr-loop.env in the target repo and edit paths/PRs.

WORKSPACE_LABEL=jai-pr-loop
PROJECT_REPO=/path/to/jai-pr

GUIDANCE_DIR=

AGENT_BIN=claude
AGENT_ARGS=--permission-mode auto
POLL_SECONDS=120
SYNC_MODE=remote
TASK_NAME=japan-ai-pr-12499

PARENT_PR=12499
PR_NUMBERS=12499 13045 12886
CHILD_PRS=13045 12886
PARENT_BRANCH=feat/ontoloty-sfa-alternative

REVIEW_DIR=$PROJECT_REPO/.herdr-loop
FEEDBACK_MD=$REVIEW_DIR/feedback.md
FEEDBACK_LOCK_MD=$REVIEW_DIR/feedback.lock.md
REVIEW_MD=$REVIEW_DIR/review.md
RUN_LOG_MD=$REVIEW_DIR/loop-run-log.md
BUDGET_MD=$REVIEW_DIR/loop-budget.md
DENYLIST_MD=$REVIEW_DIR/denylist.md
PAUSE_FILE=$REVIEW_DIR/PAUSE

MAX_ATTEMPTS=3
MAX_SUBAGENTS_PER_RUN=6
TOKEN_BUDGET_DAILY=2000000
AUTO_MERGE=false
ALLOW_REMOTE=true
ALLOW_DESTRUCTIVE=false
