# Example only. Copy to herd.conf.sh and edit paths/PRs.

WORKSPACE_LABEL=jai-pr-loop
JAI_REPO=/path/to/jai-pr

GUIDANCE_DIR=

AGENT_BIN=claude
AGENT_ARGS=--permission-mode auto
POLL_SECONDS=120
SYNC_MODE=remote
TASK_NAME=japan-ai-pr-12499

PARENT_PR=12499
PR_NUMBERS=12499 13045 12886
CHILD_PRS=13045 12886
PARENT_BRANCH=feat/ontoloty-sfa-alternative

REVIEW_DIR=$PWD/.herdr-pr-loop
FEEDBACK_MD=$REVIEW_DIR/feedback.md
FEEDBACK_LOCK_MD=$REVIEW_DIR/feedback.lock.md
REVIEW_MD=$REVIEW_DIR/review.md
